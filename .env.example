# 로컬 Docker Compose(Oracle Cloud 등 자체 호스팅)용 기본값
DB_HOST=postgres
DB_PORT=5432
DB_NAME=fishingapp
DB_USERNAME=fishinguser
DB_PASSWORD=change-me
# DB_PARAMS=?sslmode=require   # Neon 등 SSL 필수 호스트 사용 시 주석 해제

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me
REDIS_SSL=false   # Upstash 등 TLS 필수 호스트 사용 시 true

JWT_SECRET=fishing-app-secret-key-must-be-at-least-256-bits-long-for-hs256
KMA_API_KEY=
KHOA_API_KEY=
